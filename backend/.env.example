# --- Server ---
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# --- Database (Postgres via Prisma) ---
DATABASE_URL="postgresql://sher:sher_dev_password@localhost:5432/sher?schema=public"

# --- Redis (price cache + rate-limit store) ---
REDIS_URL="redis://localhost:6379"

# --- Auth ---
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# --- Market data provider ---
# Sher uses Twelve Data (https://twelvedata.com) for real, licensed forex
# market data. Free tier is sufficient for a modest pair list at a slower
# refresh interval. Get a key at https://twelvedata.com/pricing
TWELVE_DATA_API_KEY="your-twelve-data-api-key"
TWELVE_DATA_BASE_URL="https://api.twelvedata.com"

# How often (ms) the backend polls the provider per pair/timeframe.
# Respect your plan's rate limit — free tier is typically 8 req/min.
MARKET_DATA_POLL_INTERVAL_MS=15000

# --- Logging ---
LOG_LEVEL=info
